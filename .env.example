# --- HTTP ---
PORT=8080
LOG_LEVEL=info
NODE_ENV=development
BODY_LIMIT_BYTES=1048576

# --- PostgreSQL ---
DATABASE_URL=postgres://authorizer:authorizer@postgres:5432/authorizer
PG_POOL_MAX=10

# --- Redis (dedicated instance; maxmemory-policy noeviction) ---
REDIS_URL=redis://redis:6379

# --- Quota / reservations ---
RESERVATION_TTL_SECONDS=600
OVERAGE_ALLOWANCE=0
QUOTA_PERIOD_GRACE_SECONDS=86400

# --- AI token -> point mapping (never 1:1) ---
POINTS_PER_1K_TOKENS=1

# --- Subscription hot-path cache ---
SUBSCRIPTION_CACHE_TTL_SECONDS=45

# --- Internal service-to-service auth for /internal/quota/* ---
INTERNAL_SERVICE_TOKEN_SECRET=change-me-in-secret-manager

# --- JWT (used from Phase 2) ---
JWKS_URI=https://issuer.example.com/.well-known/jwks.json
JWT_ISSUER=https://issuer.example.com/
JWT_AUDIENCE=api://main-app
JWT_ALGS=RS256
