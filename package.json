{
  "name": "subscription-authorizer",
  "version": "1.0.0",
  "description": "External subscription/points authorizer for NGINX Ingress auth-request",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && cp -r src/database/migrations dist/database/migrations && cp -r src/redis/scripts dist/redis/scripts",
    "start": "node dist/server.js",
    "migrate": "node dist/database/migrate.js",
    "dev": "tsx watch src/server.ts",
    "migrate:dev": "tsx src/database/migrate.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "fastify": "^4.28.1",
    "ioredis": "^5.4.1",
    "jose": "^5.9.6",
    "pg": "^8.12.0",
    "pino": "^9.3.2",
    "prom-client": "^15.1.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "pino-pretty": "^11.2.1",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
